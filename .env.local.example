# FAL.ai API key — get from https://fal.ai/dashboard
# Set to "mock" for local dev (returns placeholder images)
FAL_KEY=your_fal_api_key_here

# Database
# Local development: SQLite via libsql (no setup needed)
DATABASE_URL="file:./dev.db"

# Production on Vercel: use Turso (libsql cloud)
# 1. Create a database: turso db create mirror-makeup
# 2. Get the URL:       turso db show mirror-makeup --url
# 3. Get auth token:    turso db tokens create mirror-makeup
# Then set in Vercel dashboard:
#   DATABASE_URL="libsql://mirror-makeup-xxx.turso.io"
#   TURSO_AUTH_TOKEN="your-auth-token"
#
# After deploy, seed the database once:
#   DATABASE_URL="libsql://..." TURSO_AUTH_TOKEN="..." npm run db:seed
